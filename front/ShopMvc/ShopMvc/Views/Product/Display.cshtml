@model ShopMvc.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2>Chi tiết sản phẩm</h2>
<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Giá</dt>
    <dd class="col-sm-10">@Model.Price.ToString("#,##0") ₫</dd>
    <dt class="col-sm-2">Mô tả</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>
<a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name"
             style="width:300px;height:auto;border-radius:10px;" />
    }
</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>